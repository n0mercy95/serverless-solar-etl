# Google Cloud Platform (GCP) Configuration
GCP_PROJECT_ID=my-gcp-project-id
GOOGLE_APPLICATION_CREDENTIALS=/app/credentials.json # O usar Workload Identity en Cloud Run

# BigQuery Configuration
BQ_DATASET_ID=solar_etl_dataset
BQ_TABLE_ID=pvod_metrics

# Google Cloud Storage Configuration (Gold Layer Buffer)
GCS_BUCKET_NAME=my-pvod-gold-bucket

# Data Sources (Ingestion)
GITHUB_RAW_URL=https://raw.githubusercontent.com/user/repo/main/pvod.csv
SCIDB_FALLBACK_URL=https://scidb.cn/api/v1/dataset/pvod.csv

# Application Settings
ENVIRONMENT=development
LOG_LEVEL=INFO
